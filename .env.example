RGA_USE_MOCK_LLM=true
RGA_USE_MOCK_SOURCE=true

RGA_LLM_PROVIDER=openai

# Accepts ANTHROPIC_API_KEY too.
RGA_ANTHROPIC_API_KEY=
RGA_LLM_MODEL=claude-opus-4-8

# --- OpenAI (real LLM) ----------------------------------------------------
# Accepts the standard OPENAI_API_KEY too, so an existing key just works.
RGA_OPENAI_API_KEY=
RGA_OPENAI_MODEL=gpt-4o-mini

# --- Adzuna (live job source) --------------------------------------------
# Free API keys: https://developer.adzuna.com/
RGA_ADZUNA_APP_ID=
RGA_ADZUNA_APP_KEY=
RGA_ADZUNA_COUNTRY=sg
